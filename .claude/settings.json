{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(flutter *)",
      "Bash(pod *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(curl *)",
      "Bash(xcrun *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git commit*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*.pem)"
    ]
  }
}
