# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/verifia_dev"

# JWT signing key — ES256 (ECDSA P-256)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out private.pem
# Then: cat private.pem | base64 (store base64 in this variable)
JWT_PRIVATE_KEY_PEM="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"

# Token configuration
TOKEN_TTL_SECONDS=300          # 5 minutes (2–10 min range)
CHALLENGE_TTL_SECONDS=600      # 10 minutes for QR challenge

# App Attest (Apple DeviceCheck)
APPLE_TEAM_ID="YOUR_TEAM_ID"
APPLE_APP_BUNDLE_ID="com.verifia.app"
# Skip attestation in CI/simulator (never true in production)
VERIFIA_SKIP_ATTEST=false

# FaceTec (Managed Testing API)
FACETEC_BASE_URL="https://api.facetec.com/api/v3.1/biometric-console"
FACETEC_DEVICE_KEY_IDENTIFIER="YOUR_DEVICE_KEY"
FACETEC_PUBLIC_FHD_KEY="YOUR_FHD_KEY"
FACETEC_SERVER_SESSION_TOKEN_ENCRYPTION_SECRET="YOUR_SECRET"

# API
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# JWT issuer/audience
JWT_ISSUER="https://api.verifia.dev"
