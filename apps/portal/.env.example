# Backend API URL
VITE_API_URL=http://localhost:3001

# Verifier API key — sent as X-API-Key header
# This defines the `aud` (audience) claim in issued JWTs.
# Each verifier organization gets a unique key.
VITE_VERIFIER_API_KEY=demo-verifier-key-change-me

# Polling interval (ms) for badge status
VITE_POLL_INTERVAL_MS=2000
