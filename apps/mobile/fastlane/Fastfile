default_platform :ios

platform :ios do
  desc "Build Flutter app and upload to TestFlight"
  lane :beta do
    # Authenticate with App Store Connect API key (no 2FA needed in CI)
    api_key = app_store_connect_api_key(
      key_id:                  ENV["ASC_KEY_ID"],
      issuer_id:               ENV["ASC_ISSUER_ID"],
      key_content:             ENV["ASC_KEY_CONTENT"],
      is_key_content_base64:   true,
    )

    # Bump build number using the CI run number so it always increments
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "ios/Runner.xcodeproj",
    )

    # Build the iOS app via Xcode
    build_app(
      workspace:      "ios/Runner.xcworkspace",
      scheme:         "Runner",
      configuration:  "Release",
      export_method:  "app-store",
      export_options: {
        provisioningProfiles: {
          "com.verifia.verifiaMobile" => ENV["PROVISIONING_PROFILE_NAME"],
        },
      },
      # Pass dart-defines so the release build points to the production API
      xcargs: "DART_DEFINES='#{[
        "VERIFIA_API_URL=#{ENV["VERIFIA_API_URL_PROD"]}",
        "VERIFIA_SKIP_ATTEST=false",
      ].map { |d| Base64.strict_encode64(d) }.join(",")}'",
    )

    # Upload IPA to TestFlight — skip waiting for Apple's processing
    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Build #{ENV["BUILD_NUMBER"]} — auto deploy desde main",
    )
  end
end
